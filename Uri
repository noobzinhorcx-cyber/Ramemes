<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Jogo de Conversa</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #2c3e50;
            color: #ecf0f1;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }
        #chat-container {
            background-color: #34495e;
            width: 100%;
            max-width: 500px;
            border-radius: 10px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
            display: flex;
            flex-direction: column;
            height: 80vh;
            overflow: hidden;
        }
        #header {
            background-color: #2980b9;
            padding: 15px;
            text-align: center;
            font-weight: bold;
            font-size: 1.2em;
        }
        #messages {
            flex-grow: 1;
            padding: 15px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        .message {
            background-color: #2c3e50;
            padding: 10px;
            border-radius: 8px;
            word-wrap: break-word;
        }
        .message .username {
            font-weight: bold;
            color: #f1c40f;
            margin-bottom: 5px;
            display: block;
            font-size: 0.9em;
        }
        #input-area {
            display: flex;
            padding: 15px;
            background-color: #1a252f;
            gap: 10px;
        }
        input[type="text"] {
            padding: 10px;
            border: none;
            border-radius: 5px;
            outline: none;
        }
        #username-input {
            width: 30%;
        }
        #msg-input {
            flex-grow: 1;
        }
        button {
            background-color: #27ae60;
            color: white;
            border: none;
            padding: 10px 15px;
            border-radius: 5px;
            cursor: pointer;
            font-weight: bold;
            transition: background 0.3s;
        }
        button:hover {
            background-color: #2ecc71;
        }
    </style>
</head>
<body>

    <div id="chat-container">
        <div id="header">RPG / Chat Room</div>
        <div id="messages"></div>
        <div id="input-area">
            <input type="text" id="username-input" placeholder="Seu Nome" value="Jogador1">
            <input type="text" id="msg-input" placeholder="Digite sua mensagem...">
            <button id="send-btn">Enviar</button>
        </div>
    </div>

    <script type="module">
        // Importa as funções do Firebase via CDN
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.8.1/firebase-app.js";
        import { getDatabase, ref, push, onChildAdded } from "https://www.gstatic.com/firebasejs/10.8.1/firebase-database.js";

        // Sua configuração do Firebase
        const firebaseConfig = {
            apiKey: "AIzaSyBgxQ5iZlUoRllvwuGWYX-RLySsOf0x4Q4",
            authDomain: "fir-f15a4.firebaseapp.com",
            databaseURL: "https://fir-f15a4-default-rtdb.firebaseio.com",
            projectId: "fir-f15a4",
            storageBucket: "fir-f15a4.firebasestorage.app",
            messagingSenderId: "704481061148",
            appId: "1:704481061148:web:498953aa5ab5a1f80a32d9",
            measurementId: "G-0R9R4DDG4Z"
        };

        // Inicializa o Firebase
        const app = initializeApp(firebaseConfig);
        
        // Inicializa o Realtime Database
        const db = getDatabase(app);
        const chatRef = ref(db, 'mensagens_jogo');

        // Elementos do DOM
        const messagesDiv = document.getElementById('messages');
        const msgInput = document.getElementById('msg-input');
        const usernameInput = document.getElementById('username-input');
        const sendBtn = document.getElementById('send-btn');

        // Função para enviar mensagem para o Firebase
        function sendMessage() {
            const username = usernameInput.value.trim() || "Anônimo";
            const message = msgInput.value.trim();

            if (message !== "") {
                // Envia os dados para o banco
                push(chatRef, {
                    usuario: username,
                    texto: message,
                    timestamp: Date.now()
                });
                msgInput.value = ""; // Limpa o campo
            }
        }

        // Evento de clique no botão
        sendBtn.addEventListener('click', sendMessage);

        // Evento de apertar "Enter" no teclado
        msgInput.addEventListener('keypress', function (e) {
            if (e.key === 'Enter') {
                sendMessage();
            }
        });

        // Escuta o Firebase para novas mensagens em tempo real
        onChildAdded(chatRef, (snapshot) => {
            const data = snapshot.val();
            
            // Cria os elementos HTML da mensagem
            const msgElement = document.createElement('div');
            msgElement.classList.add('message');
            
            const userElement = document.createElement('span');
            userElement.classList.add('username');
            userElement.innerText = data.usuario;
            
            const textElement = document.createElement('span');
            textElement.innerText = data.texto;

            msgElement.appendChild(userElement);
            msgElement.appendChild(textElement);
            
            messagesDiv.appendChild(msgElement);

            // Rola automaticamente para a última mensagem
            messagesDiv.scrollTop = messagesDiv.scrollHeight;
        });
    </script>
</body>
</html>
